#!/usr/bin/env bash
set -euo pipefail

# Keep this wrapper next to the repo so contributors can run `./crawbl`
# without caring whether the local binary has been built yet.
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
binary_path="${repo_root}/bin/crawbl"
tmp_binary="${binary_path}.tmp"

needs_build=false

# First run or a cleaned repo: there is nothing to execute yet.
if [[ ! -x "${binary_path}" ]]; then
  needs_build=true
fi

# Escape hatch when you want to force a fresh build without deleting `bin/`.
if [[ "${CRAWBL_REBUILD:-0}" == "1" ]]; then
  needs_build=true
fi

if [[ "${needs_build}" == "false" ]]; then
  # Dependency metadata changing is enough to invalidate the binary even if
  # the application source itself has not moved yet.
  for watched in "${repo_root}/go.mod" "${repo_root}/go.sum" "${repo_root}/vendor/modules.txt"; do
    if [[ "${watched}" -nt "${binary_path}" ]]; then
      needs_build=true
      break
    fi
  done
fi

# This is the actual source tree that feeds the CLI. `find ... -print -quit`
# keeps the check cheap by stopping at the first newer file.
if [[ "${needs_build}" == "false" ]] && find \
  "${repo_root}/api" \
  "${repo_root}/cmd/crawbl" \
  "${repo_root}/internal" \
  -type f -newer "${binary_path}" -print -quit | grep -q .; then
  needs_build=true
fi

if [[ "${needs_build}" == "true" ]]; then
  mkdir -p "${repo_root}/bin"
  echo "Building repo-local crawbl binary..."
  (
    cd "${repo_root}"
    # Build into a temp path first so an interrupted build never leaves behind
    # a half-written executable that looks valid.
    go build -mod=vendor -o "${tmp_binary}" ./cmd/crawbl
  )
  mv "${tmp_binary}" "${binary_path}"
  chmod +x "${binary_path}"
fi

# Replace the shell with the real CLI so exit codes and signals pass through.
exec "${binary_path}" "$@"
