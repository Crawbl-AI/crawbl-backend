#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
binary_path="${repo_root}/bin/crawbl"
tmp_binary="${binary_path}.tmp"

needs_build=false

if [[ ! -x "${binary_path}" ]]; then
  needs_build=true
fi

if [[ "${CRAWBL_REBUILD:-0}" == "1" ]]; then
  needs_build=true
fi

if [[ "${needs_build}" == "false" ]]; then
  for watched in "${repo_root}/go.mod" "${repo_root}/go.sum" "${repo_root}/vendor/modules.txt"; do
    if [[ "${watched}" -nt "${binary_path}" ]]; then
      needs_build=true
      break
    fi
  done
fi

if [[ "${needs_build}" == "false" ]] && find \
  "${repo_root}/api" \
  "${repo_root}/cmd/crawbl" \
  "${repo_root}/internal" \
  -type f -newer "${binary_path}" -print -quit | grep -q .; then
  needs_build=true
fi

if [[ "${needs_build}" == "true" ]]; then
  mkdir -p "${repo_root}/bin"
  echo "Building repo-local crawbl binary..."
  (
    cd "${repo_root}"
    go build -mod=vendor -o "${tmp_binary}" ./cmd/crawbl
  )
  mv "${tmp_binary}" "${binary_path}"
  chmod +x "${binary_path}"
fi

exec "${binary_path}" "$@"
