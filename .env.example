# ============================================================================
# Crawbl Backend — Environment Variables
# ============================================================================
# Copy to .env and fill in the values.
# See CLAUDE.md for usage: set -a && source .env && set +a && <command>
# ============================================================================

# Tells docker-compose / tooling which file to load
ENV_FILE=.env

# ============================================================================
# Docker Compose — Postgres container
# ============================================================================
# Only used by the local docker-compose postgres service.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crawbl

# ============================================================================
# Orchestrator — Core
# ============================================================================

# HTTP listen port for the orchestrator API
CRAWBL_SERVER_PORT=7171

# Persistence backend ("postgres" for all non-test paths)
CRAWBL_SERVER_STORAGE_BACKEND=postgres

# Environment name: local | dev | staging | prod
CRAWBL_ENVIRONMENT=local

# Shared HMAC secret for request signing between services
CRAWBL_HTTP_HMAC_SECRET=dev-shared-secret

# Allow "dev-<anything>" tokens to bypass auth (dev/local only, empty in prod)
CRAWBL_AUTH_ALLOW_DEV_TOKENS=true

# Prefix for dev auth tokens (tokens matching "<prefix>-*" are accepted)
AUTH_DEV_TOKEN_PREFIX=dev

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# ============================================================================
# Database — PostgreSQL (orchestrator)
# ============================================================================

# Connection parameters for the orchestrator database
CRAWBL_DATABASE_HOST=postgresdb
CRAWBL_DATABASE_PORT=5432
CRAWBL_DATABASE_USER=postgres
CRAWBL_DATABASE_PASSWORD=postgres
CRAWBL_DATABASE_NAME=crawbl
CRAWBL_DATABASE_SCHEMA=orchestrator
CRAWBL_DATABASE_SSLMODE=disable

# Connection pool tuning
CRAWBL_DATABASE_MAX_OPEN_CONNECTIONS=20
CRAWBL_DATABASE_MAX_IDLE_CONNECTIONS=10
CRAWBL_DATABASE_CONN_MAX_LIFETIME=5m

# ============================================================================
# Redis / Valkey
# ============================================================================

# Redis address (host:port) — used by orchestrator for caching and sessions
CRAWBL_REDIS_ADDR=localhost:6379
CRAWBL_REDIS_PASSWORD=
CRAWBL_REDIS_DB=0
CRAWBL_REDIS_TLS=false

# ============================================================================
# Legal
# ============================================================================

# URLs and versions shown during onboarding consent flow
CRAWBL_LEGAL_TERMS_OF_SERVICE=https://crawbl.com/terms
CRAWBL_LEGAL_PRIVACY_POLICY=https://crawbl.com/privacy
CRAWBL_LEGAL_TERMS_OF_SERVICE_VERSION=v1
CRAWBL_LEGAL_PRIVACY_POLICY_VERSION=v1

# ============================================================================
# User Swarm Runtime
# ============================================================================

# Runtime driver: "fake" (mock replies, no K8s), "crawbl-runtime" (real pods)
CRAWBL_RUNTIME_DRIVER=fake

# Prefix for fake runtime replies (only used when driver=fake)
CRAWBL_RUNTIME_FAKE_REPLY_PREFIX=FakeRuntimeReply

# K8s namespace where runtime pods are deployed
CRAWBL_RUNTIME_NAMESPACE=swarms-dev

# Container image for agent-runtime pods (empty = use default)
CRAWBL_RUNTIME_IMAGE=

# K8s image pull secret name for pulling from DOCR
CRAWBL_RUNTIME_IMAGE_PULL_SECRET=crawbl-docr

# Persistent storage for runtime workspace cache
CRAWBL_RUNTIME_STORAGE_SIZE=2Gi
CRAWBL_RUNTIME_STORAGE_CLASS_NAME=

# Default LLM provider and model for new runtimes
CRAWBL_RUNTIME_DEFAULT_PROVIDER=openai
CRAWBL_RUNTIME_DEFAULT_MODEL=gpt-4o-mini

# K8s secret containing env vars injected into runtime pods (managed by ESO)
CRAWBL_RUNTIME_ENV_SECRET_NAME=

# TOML config overrides injected into runtime pods (base64-encoded)
CRAWBL_RUNTIME_TOML_OVERRIDES=

# How long to wait for a runtime pod to become ready, and how often to poll
CRAWBL_RUNTIME_POLL_TIMEOUT=60s
CRAWBL_RUNTIME_POLL_INTERVAL=2s

# gRPC port the runtime pod listens on (must match agent-runtime binary)
CRAWBL_RUNTIME_PORT=42618

# ============================================================================
# MCP (Model Context Protocol)
# ============================================================================

# Shared HMAC secret for per-swarm MCP bearer tokens — must match webhook env
CRAWBL_MCP_SIGNING_KEY=

# URL runtime pods use to reach the MCP server (cluster-internal DNS)
CRAWBL_MCP_ENDPOINT=http://orchestrator.backend.svc.cluster.local:7171/mcp/v1

# ============================================================================
# Runtime Cluster — Prod Hybrid (optional)
# ============================================================================

# Path to kubeconfig for the remote runtime k3s cluster.
# When set, the orchestrator targets this cluster for UserSwarm CRs
# instead of the local in-cluster API. Leave empty for single-cluster dev.
CRAWBL_RUNTIME_CLUSTER_KUBECONFIG=

# mTLS certificates for cross-cluster gRPC to runtime pods.
# Required when CRAWBL_RUNTIME_CLUSTER_KUBECONFIG is set.
# Leave empty for single-cluster dev (insecure cluster-internal transport).
CRAWBL_TLS_CERT=
CRAWBL_TLS_KEY=
CRAWBL_TLS_CA=

# ============================================================================
# Embedding & LLM (Memory Stack)
# ============================================================================

# Embedding provider (memory stack disabled if BASE_URL is empty)
CRAWBL_EMBED_BASE_URL=https://api.openai.com/v1
CRAWBL_EMBED_API_KEY=
CRAWBL_EMBED_MODEL=text-embedding-3-small

# LLM provider for memory classification (falls back to EMBED_BASE_URL/API_KEY)
CRAWBL_LLM_BASE_URL=https://api.openai.com/v1
CRAWBL_LLM_API_KEY=

# Model for intent classification / memory heuristics
CRAWBL_CLASSIFY_MODEL=gpt-4o-mini

# ============================================================================
# Routing LLM
# ============================================================================

# Invisible infrastructure switch for simple/group classification
# Uses its own key so it can be a cheaper/faster model than the main LLM
CRAWBL_ROUTING_API_KEY=
CRAWBL_ROUTING_MODEL=gpt-4o-mini
CRAWBL_ROUTING_TIMEOUT=5s

# ============================================================================
# OpenAI
# ============================================================================

# OpenAI API key — used by agent runtime for LLM calls
OPENAI_API_KEY=

# ============================================================================
# FCM — Firebase Cloud Messaging (push notifications)
# ============================================================================

# Firebase project ID and service account JSON path (empty = notifications disabled)
CRAWBL_FCM_PROJECT_ID=
CRAWBL_FCM_SERVICE_ACCOUNT_PATH=

# ============================================================================
# ClickHouse (usage analytics)
# ============================================================================

# ClickHouse connection DSN and credentials
CRAWBL_CLICKHOUSE_DSN=clickhouse://default:password@localhost:9000/default
CRAWBL_CLICKHOUSE_PASSWORD=

# ============================================================================
# NATS (usage event streaming)
# ============================================================================

# NATS server URL and auth token
CRAWBL_NATS_URL=nats://localhost:4222
CRAWBL_NATS_TOKEN=

# ============================================================================
# Infrastructure — Pulumi / Cloud Providers
# ============================================================================

# Pulumi access token for state management
PULUMI_ACCESS_TOKEN=

# DigitalOcean API token and project settings
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_VPC_ID=
DIGITALOCEAN_PROJECT_NAME=

# Cloudflare API token and zone for DNS management
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_NAME=crawbl.com

# DNS record for the dev API endpoint
DNS_RECORD_NAME=dev.api.crawbl.com

# Email for ACME/Let's Encrypt certificates
ACME_EMAIL=admin@crawbl.com

# Pulumi ESC environment name (optional — injects provider tokens automatically)
# CRAWBL_ESC_ENV=

# Cloudflare Tunnel secret (optional — only needed when ManageTunnel=true)
# CLOUDFLARE_TUNNEL_SECRET=

# ============================================================================
# Infrastructure — ArgoCD
# ============================================================================

# SSH private key for ArgoCD to access the crawbl-argocd-apps repo
# Provide either the raw key content or a file path (not both)
# ARGOCD_SSH_PRIVATE_KEY=
ARGOCD_SSH_KEY_PATH=~/.ssh/id_ed25519

# ============================================================================
# Infrastructure — AWS (External Secrets Operator)
# ============================================================================

# AWS credentials for ESO to read secrets from AWS Secrets Manager
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1

# ============================================================================
# Infrastructure — DigitalOcean Spaces (infra destroy cleanup)
# ============================================================================

# Spaces access keys for cleaning up orphaned buckets during infra destroy
# Get from DO console > API > Spaces Keys
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=

# ============================================================================
# Infrastructure — Hetzner Cloud (k3s dev cluster)
# ============================================================================

# Hetzner Cloud API token for provisioning k3s dev infrastructure
HCLOUD_TOKEN=

# ============================================================================
# River UI (job queue dashboard)
# ============================================================================

# Basic auth for the River UI dashboard (https://dev.river.crawbl.com)
# Also mirrored to AWS Secrets Manager at crawbl/dev/riverui/auth
RIVERUI_BASIC_AUTH_USER=admin
RIVERUI_BASIC_AUTH_PASSWORD=

# ============================================================================
# SonarQube (code quality)
# ============================================================================

# SonarQube PostgreSQL password (in backend-postgresql)
# Mirrored to AWS Secrets Manager at crawbl/dev/sonarqube/postgresql
SONARQUBE_JDBC_PASSWORD=

# SonarQube API token and URL for CI integration
SONARQUBE_TOKEN=
SONARQUBE_URL=

# ============================================================================
# E2E Testing
# ============================================================================

# Auth bypass token for E2E tests (dev only — empty in production)
CRAWBL_E2E_TOKEN=

# ============================================================================
# Container Registry
# ============================================================================

# Base URL for the container registry (used by crawbl app build/deploy)
# CRAWBL_REGISTRY=registry.digitalocean.com/crawbl

# ============================================================================
# Telemetry — OpenTelemetry (optional, prod only)
# ============================================================================

# Enable/disable OpenTelemetry metrics export
# CRAWBL_OTEL_ENABLED=false
# CRAWBL_OTEL_METRICS_ENDPOINT=
# CRAWBL_OTEL_SERVICE_NAME=orchestrator
# CRAWBL_OTEL_SERVICE_VERSION=
# CRAWBL_OTEL_ENVIRONMENT=dev
# CRAWBL_OTEL_NAMESPACE=crawbl
# CRAWBL_OTEL_EXPORT_INTERVAL=30s
