ENV_FILE=.env

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crawbl

CRAWBL_SERVER_PORT=7171
CRAWBL_ENVIRONMENT=local
CRAWBL_HTTP_HMAC_SECRET=dev-shared-secret
CRAWBL_AUTH_ALLOW_DEV_TOKENS=true
CRAWBL_FIREBASE_CREDENTIALS_FILE=
CRAWBL_FIREBASE_CREDENTIALS_JSON=

CRAWBL_DATABASE_HOST=postgresdb
CRAWBL_DATABASE_PORT=5432
CRAWBL_DATABASE_USER=postgres
CRAWBL_DATABASE_PASSWORD=postgres
CRAWBL_DATABASE_NAME=crawbl
CRAWBL_DATABASE_SCHEMA=orchestrator
CRAWBL_DATABASE_SSLMODE=disable
CRAWBL_DATABASE_MAX_OPEN_CONNECTIONS=20
CRAWBL_DATABASE_MAX_IDLE_CONNECTIONS=10
CRAWBL_DATABASE_CONN_MAX_LIFETIME=5m

AUTH_DEV_TOKEN_PREFIX=dev
CRAWBL_LEGAL_TERMS_OF_SERVICE=https://crawbl.com/terms
CRAWBL_LEGAL_PRIVACY_POLICY=https://crawbl.com/privacy
CRAWBL_LEGAL_TERMS_OF_SERVICE_VERSION=v1
CRAWBL_LEGAL_PRIVACY_POLICY_VERSION=v1

CRAWBL_RUNTIME_DRIVER=fake
CRAWBL_RUNTIME_FAKE_REPLY_PREFIX=FakeRuntimeReply
CRAWBL_RUNTIME_NAMESPACE=swarms-dev
CRAWBL_RUNTIME_IMAGE=
CRAWBL_RUNTIME_IMAGE_PULL_SECRET=crawbl-docr
CRAWBL_RUNTIME_STORAGE_SIZE=2Gi
CRAWBL_RUNTIME_STORAGE_CLASS_NAME=
CRAWBL_RUNTIME_DEFAULT_PROVIDER=openai
CRAWBL_RUNTIME_DEFAULT_MODEL=gpt-5.4
CRAWBL_RUNTIME_ENV_SECRET_NAME=
CRAWBL_RUNTIME_TOML_OVERRIDES=
CRAWBL_RUNTIME_POLL_TIMEOUT=60s
CRAWBL_RUNTIME_POLL_INTERVAL=2s
CRAWBL_RUNTIME_PORT=42617

# Infrastructure (Pulumi)
PULUMI_ACCESS_TOKEN=
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_VPC_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_NAME=crawbl.com
DNS_RECORD_NAME=dev.api.crawbl.com
ACME_EMAIL=admin@crawbl.com
